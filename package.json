  "bugs": {
    "url": "https://github.com/Kemont2H/FindBugsUI/issues"
  },
  "homepage": "https://github.com/Kemont2H/FindBugsUI#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1"
  }
}
